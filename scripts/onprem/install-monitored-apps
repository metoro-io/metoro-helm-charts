#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
DEFAULT_ONPREM_MONITORED_KUBECONFIG="${REPO_ROOT}/../metoro-observability/deployments/onprem/.state/monitored-kubeconfig"

: "${ONPREM_MONITORED_KUBECONFIG:=${DEFAULT_ONPREM_MONITORED_KUBECONFIG}}"
: "${ONPREM_MONITORED_APP_TIMEOUT:=5m}"

: "${ONPREM_INSTALL_PROMETHEUS_OPERATOR_CRDS:=true}"
: "${ONPREM_PROMETHEUS_OPERATOR_CRDS_NAMESPACE:=monitoring}"
: "${ONPREM_PROMETHEUS_OPERATOR_CRDS_RELEASE:=prometheus-operator-crds}"
: "${ONPREM_PROMETHEUS_OPERATOR_CRDS_CHART_VERSION:=29.0.0}"

: "${ONPREM_INSTALL_PODINFO:=true}"
: "${ONPREM_PODINFO_NAMESPACE:=servicemonitor-fixtures}"
: "${ONPREM_PODINFO_RELEASE:=podinfo}"
: "${ONPREM_PODINFO_CHART_VERSION:=6.13.0}"
: "${ONPREM_PODINFO_REPLICAS:=1}"
: "${ONPREM_PODINFO_SERVICE_MONITOR_INTERVAL:=15s}"

usage() {
  cat <<'EOF'
Usage: scripts/onprem/install-monitored-apps

Installs small ServiceMonitor-backed applications into the on-prem monitored
cluster for exporter scraping tests.

Defaults:
  - Kubeconfig:
    ../metoro-observability/deployments/onprem/.state/monitored-kubeconfig
  - Prometheus Operator CRDs chart:
    prometheus-community/prometheus-operator-crds 29.0.0
  - Podinfo chart:
    podinfo/podinfo 6.13.0
  - Podinfo namespace:
    servicemonitor-fixtures

Environment overrides:
  ONPREM_MONITORED_KUBECONFIG
  ONPREM_INSTALL_PROMETHEUS_OPERATOR_CRDS
  ONPREM_PROMETHEUS_OPERATOR_CRDS_NAMESPACE
  ONPREM_PROMETHEUS_OPERATOR_CRDS_RELEASE
  ONPREM_PROMETHEUS_OPERATOR_CRDS_CHART_VERSION
  ONPREM_INSTALL_PODINFO
  ONPREM_PODINFO_NAMESPACE
  ONPREM_PODINFO_RELEASE
  ONPREM_PODINFO_CHART_VERSION
  ONPREM_PODINFO_REPLICAS
  ONPREM_PODINFO_SERVICE_MONITOR_INTERVAL
  ONPREM_MONITORED_APP_TIMEOUT
EOF
}

log() {
  printf '[onprem-monitored-apps] %s\n' "$*"
}

die() {
  printf '[onprem-monitored-apps] ERROR: %s\n' "$*" >&2
  exit 1
}

require_command() {
  local command_name
  for command_name in "$@"; do
    command -v "${command_name}" >/dev/null 2>&1 || die "Missing required command: ${command_name}"
  done
}

require_boolean() {
  local variable_name="$1"
  local value="${!variable_name:-}"

  [[ "${value}" == "true" || "${value}" == "false" ]] || die "${variable_name} must be true or false"
}

require_positive_integer() {
  local variable_name="$1"
  local value="${!variable_name:-}"

  [[ "${value}" =~ ^[1-9][0-9]*$ ]] || die "${variable_name} must be a positive integer"
}

ensure_kubeconfig() {
  [[ -n "${ONPREM_MONITORED_KUBECONFIG}" ]] || die "ONPREM_MONITORED_KUBECONFIG is empty"

  if [[ "${ONPREM_MONITORED_KUBECONFIG}" != *:* ]]; then
    [[ -f "${ONPREM_MONITORED_KUBECONFIG}" ]] || die "Missing monitored cluster kubeconfig at ${ONPREM_MONITORED_KUBECONFIG}"
  fi
}

install_prometheus_operator_crds() {
  if [[ "${ONPREM_INSTALL_PROMETHEUS_OPERATOR_CRDS}" != "true" ]]; then
    log "Skipping Prometheus Operator CRDs because ONPREM_INSTALL_PROMETHEUS_OPERATOR_CRDS=false"
    return 0
  fi

  log "Installing Prometheus Operator CRDs ${ONPREM_PROMETHEUS_OPERATOR_CRDS_CHART_VERSION}"
  helm repo add prometheus-community https://prometheus-community.github.io/helm-charts >/dev/null 2>&1 || true
  helm repo update prometheus-community >/dev/null

  KUBECONFIG="${ONPREM_MONITORED_KUBECONFIG}" helm upgrade --install \
    "${ONPREM_PROMETHEUS_OPERATOR_CRDS_RELEASE}" \
    prometheus-community/prometheus-operator-crds \
    --namespace "${ONPREM_PROMETHEUS_OPERATOR_CRDS_NAMESPACE}" \
    --create-namespace \
    --version "${ONPREM_PROMETHEUS_OPERATOR_CRDS_CHART_VERSION}" \
    --wait \
    --timeout "${ONPREM_MONITORED_APP_TIMEOUT}"

  KUBECONFIG="${ONPREM_MONITORED_KUBECONFIG}" kubectl wait \
    --for=condition=Established \
    crd/servicemonitors.monitoring.coreos.com \
    --timeout "${ONPREM_MONITORED_APP_TIMEOUT}"
}

install_podinfo() {
  if [[ "${ONPREM_INSTALL_PODINFO}" != "true" ]]; then
    log "Skipping podinfo because ONPREM_INSTALL_PODINFO=false"
    return 0
  fi

  log "Installing podinfo ${ONPREM_PODINFO_CHART_VERSION} with ServiceMonitor enabled"
  helm repo add podinfo https://stefanprodan.github.io/podinfo >/dev/null 2>&1 || true
  helm repo update podinfo >/dev/null

  KUBECONFIG="${ONPREM_MONITORED_KUBECONFIG}" helm upgrade --install \
    "${ONPREM_PODINFO_RELEASE}" \
    podinfo/podinfo \
    --namespace "${ONPREM_PODINFO_NAMESPACE}" \
    --create-namespace \
    --version "${ONPREM_PODINFO_CHART_VERSION}" \
    --set "replicaCount=${ONPREM_PODINFO_REPLICAS}" \
    --set "serviceMonitor.enabled=true" \
    --set "serviceMonitor.interval=${ONPREM_PODINFO_SERVICE_MONITOR_INTERVAL}" \
    --wait \
    --timeout "${ONPREM_MONITORED_APP_TIMEOUT}"
}

print_outputs() {
  printf '\n'
  log "Monitored cluster applications are ready"
  printf 'Kubeconfig: %s\n' "${ONPREM_MONITORED_KUBECONFIG}"
  printf 'Podinfo namespace: %s\n' "${ONPREM_PODINFO_NAMESPACE}"
  printf 'Podinfo release: %s\n' "${ONPREM_PODINFO_RELEASE}"
  printf '\n'
  printf 'Inspect ServiceMonitors:\n'
  printf '  KUBECONFIG="%s" kubectl get servicemonitor -A\n' "${ONPREM_MONITORED_KUBECONFIG}"
  printf '\n'
  printf 'Inspect podinfo resources:\n'
  printf '  KUBECONFIG="%s" kubectl -n "%s" get pods,svc,servicemonitor\n' \
    "${ONPREM_MONITORED_KUBECONFIG}" \
    "${ONPREM_PODINFO_NAMESPACE}"
  printf '\n'
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
done

require_command helm kubectl
require_boolean ONPREM_INSTALL_PROMETHEUS_OPERATOR_CRDS
require_boolean ONPREM_INSTALL_PODINFO
require_positive_integer ONPREM_PODINFO_REPLICAS
ensure_kubeconfig

log "Using monitored cluster kubeconfig ${ONPREM_MONITORED_KUBECONFIG}"
KUBECONFIG="${ONPREM_MONITORED_KUBECONFIG}" kubectl get nodes >/dev/null

install_prometheus_operator_crds
install_podinfo

print_outputs
